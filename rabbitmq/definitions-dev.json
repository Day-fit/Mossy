      "vhost": "/",
      "destination": "jwks.queue.device",
      "destination_type": "queue"
    },
    {
      "source": "fanout.jwks.exchange",
      "vhost": "/",
      "destination": "jwks.queue.password",
      "destination_type": "queue"
    },
    {
      "source": "fanout.jwks.exchange",
      "vhost": "/",
      "destination": "jwks.queue.statistics",

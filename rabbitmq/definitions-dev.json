      "write": ".*",
      "read": ".*"
    },
    {
      "user": "admin",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],
  "vhosts": [
    {
      "name": "/"
    }
  ],
  "queues": [
    {
      "name": "jwks.queue.auth",
      "vhost": "/",
      "durable": true,
      "type": "classic",
      "arguments": {
        "x-queue-type": "classic"
      }
    },
    {
      "name": "jwks.queue.device",
      "vhost": "/",
      "durable": true,
      "type": "classic",
      "arguments": {
        "x-queue-type": "classic"
      }
    },
    {
      "name": "jwks.queue.password",
      "vhost": "/",
      "durable": true,
      "type": "classic",
      "arguments": {
        "x-queue-type": "classic"
      }
    },
    {
      "name": "jwks.queue.statistics",
      "vhost": "/",
      "durable": true,
      "type": "classic",
      "arguments": {
        "x-queue-type": "classic"
      }
    },
    {
      "name": "statistics.queue.password-events",
      "vhost": "/",
      "durable": true,
      "type": "classic",
      "arguments": {
        "x-queue-type": "classic"
      }
    }
  ],
  "exchanges": [
    {
      "name": "fanout.jwks.exchange",
      "vhost": "/",
      "type": "fanout",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
